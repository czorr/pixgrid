{
  "name": "pixgrid",
  "version": "0.1.2",
  "description": "A tiny animated 3×3 pixel grid indicator for React. Zero runtime deps, multi-color and rounded-cell support out of the box.",
  "keywords": [
    "react",
    "loader",
    "spinner",
    "indicator",
    "pixel",
    "grid",
    "animation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/czorr/pixgrid"
  },
  "type": "module",
  "main": "./dist/lib/pixgrid.js",
  "module": "./dist/lib/pixgrid.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/pixgrid.js",
      "require": "./dist/lib/pixgrid.cjs"
    }
  },
  "files": [
    "dist/lib",
    "src/lib"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run clean && tsc -p tsconfig.lib.json && vite build --config vite.lib.config.ts",
    "build:demo": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
